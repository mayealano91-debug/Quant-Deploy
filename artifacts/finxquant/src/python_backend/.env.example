# ─── Alpaca Credentials ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys. .env is git-ignored.
# Get keys from: https://app.alpaca.markets/paper-dashboard (paper)
#             or https://app.alpaca.markets/live-dashboard  (live)

ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Set to FALSE to connect to live trading (requires confirmation prompt)
ALPACA_PAPER=TRUE

# Internal port for the FastAPI backend (used by Express proxy)
PYTHON_BACKEND_PORT=8001
